{
  "index": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "max_ngram_diff": 20
  },
  "analysis": {
    "analyzer": {
      "ik_max_word": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": [
          "cjk_width",
          "lowercase",
          "stop_filter",
          "synonym_filter",
          "cjk_bigram_filter"
        ]
      },
      "ik_smart_search": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": [
          "cjk_width",
          "lowercase",
          "stop_filter",
          "synonym_filter",
          "cjk_bigram_filter"
        ]
      },
      "pinyin_analyzer": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": [
          "cjk_width",
          "lowercase",
          "asciifolding",
          "unique_filter"
        ]
      },
      "prefix_analyzer": {
        "type": "custom",
        "tokenizer": "keyword",
        "filter": [
          "cjk_width",
          "lowercase",
          "edge_ngram_filter"
        ]
      },
      "prefix_search_analyzer": {
        "type": "custom",
        "tokenizer": "keyword",
        "filter": [
          "cjk_width",
          "lowercase"
        ]
      },
      "fuzzy_ngram_analyzer": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": [
          "cjk_width",
          "lowercase",
          "stop_filter",
          "cjk_bigram_filter",
          "ngram_filter"
        ]
      }
    },
    "normalizer": {
      "keyword_lowercase": {
        "type": "custom",
        "filter": [
          "cjk_width",
          "lowercase",
          "asciifolding"
        ]
      }
    },
    "filter": {
      "cjk_bigram_filter": {
        "type": "cjk_bigram",
        "output_unigrams": true
      },
      "stop_filter": {
        "type": "stop",
        "stopwords": [
          "\u7684",
          "\u4e86",
          "\u5728",
          "\u662f",
          "\u548c",
          "\u53ca",
          "\u4e0e",
          "\u6216",
          "\u5e76",
          "\u5bf9",
          "\u5230",
          "\u4ece",
          "\u88ab",
          "\u5c06",
          "\u7b49"
        ]
      },
      "synonym_filter": {
        "type": "synonym",
        "lenient": true,
        "synonyms": [
          "\u542f\u7528,\u5f00\u542f,\u6253\u5f00 => \u542f\u7528",
          "\u7981\u7528,\u5173\u95ed,\u505c\u7528 => \u7981\u7528",
          "\u521b\u5efa,\u65b0\u589e,\u6dfb\u52a0,\u5f55\u5165 => \u521b\u5efa",
          "\u66f4\u65b0,\u4fee\u6539,\u53d8\u66f4,\u7f16\u8f91 => \u66f4\u65b0",
          "\u5220\u9664,\u79fb\u9664,\u6e05\u9664,\u4f5c\u5e9f => \u5220\u9664",
          "\u8f66\u8f86,\u673a\u52a8\u8f66,\u6c7d\u8f66 => \u8f66\u8f86",
          "\u8f66\u724c,\u53f7\u724c,\u724c\u7167 => \u8f66\u724c",
          "\u9a7e\u9a76\u8bc1,\u9a7e\u7167 => \u9a7e\u9a76\u8bc1",
          "\u8fdd\u6cd5,\u8fdd\u7ae0,\u8fdd\u89c4 => \u8fdd\u6cd5",
          "\u7f5a\u6b3e,\u7f5a\u91d1 => \u7f5a\u6b3e",
          "\u6263\u5206,\u8bb0\u5206 => \u6263\u5206",
          "\u7533\u8bc9,\u590d\u8bae,\u7533\u8fa9 => \u7533\u8bc9",
          "\u7f34\u8d39,\u652f\u4ed8,\u4ed8\u6b3e => \u652f\u4ed8",
          "\u5ba1\u6838,\u5ba1\u6279,\u590d\u6838 => \u5ba1\u6838",
          "\u7528\u6237,\u8d26\u53f7,\u8d26\u6237 => \u7528\u6237",
          "\u89d2\u8272,\u6743\u9650\u7ec4 => \u89d2\u8272"
        ]
      },
      "edge_ngram_filter": {
        "type": "edge_ngram",
        "min_gram": 1,
        "max_gram": 20
      },
      "unique_filter": {
        "type": "unique",
        "only_on_same_position": false
      },
      "ngram_filter": {
        "type": "ngram",
        "min_gram": 2,
        "max_gram": 20
      }
    }
  }
}