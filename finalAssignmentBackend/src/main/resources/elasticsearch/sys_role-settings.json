{
  "index": {
    "max_ngram_diff": 20
  },
  "analysis": {
    "analyzer": {
      "ik_max_word": {
        "type": "custom",
        "tokenizer": "ik_max_word",
        "filter": [
          "cjk_width",
          "lowercase",
          "stop_filter",
          "synonym_filter"
        ]
      },
      "ik_smart_search": {
        "type": "custom",
        "tokenizer": "ik_smart",
        "filter": [
          "cjk_width",
          "lowercase",
          "stop_filter",
          "synonym_filter"
        ]
      },
      "pinyin_analyzer": {
        "type": "custom",
        "tokenizer": "ik_max_word",
        "filter": [
          "pinyin_filter",
          "lowercase",
          "unique_filter"
        ]
      },
      "prefix_analyzer": {
        "type": "custom",
        "tokenizer": "keyword",
        "filter": [
          "cjk_width",
          "lowercase",
          "edge_ngram_filter"
        ]
      },
      "prefix_search_analyzer": {
        "type": "custom",
        "tokenizer": "keyword",
        "filter": [
          "cjk_width",
          "lowercase"
        ]
      },
      "fuzzy_ngram_analyzer": {
        "type": "custom",
        "tokenizer": "ik_max_word",
        "filter": [
          "cjk_width",
          "lowercase",
          "stop_filter",
          "ngram_filter"
        ]
      }
    },
    "normalizer": {
      "keyword_lowercase": {
        "type": "custom",
        "filter": [
          "cjk_width",
          "lowercase",
          "asciifolding"
        ]
      }
    },
    "filter": {
      "stop_filter": {
        "type": "stop",
        "stopwords": [
          "的",
          "了",
          "在",
          "是",
          "和",
          "与",
          "及",
          "或",
          "并",
          "对",
          "为",
          "到",
          "从",
          "把",
          "被",
          "将",
          "等"
        ]
      },
      "synonym_filter": {
        "type": "synonym",
        "lenient": true,
        "synonyms": [
          "启用,开启,打开 => 启用",
          "禁用,关闭,停用 => 禁用",
          "创建,新增,添加,录入 => 创建",
          "更新,修改,变更,编辑 => 更新",
          "删除,移除,清除,作废 => 删除",
          "车辆,机动车,汽车 => 车辆",
          "车牌,号牌,牌照 => 车牌",
          "驾驶证,驾照 => 驾驶证",
          "违法,违章,违规 => 违法",
          "罚款,罚金 => 罚款",
          "扣分,记分 => 扣分",
          "申诉,复议,申辩 => 申诉",
          "缴费,支付,付款 => 支付",
          "审核,审批,复核 => 审核",
          "用户,账号,账户 => 用户",
          "角色,权限组 => 角色"
        ]
      },
      "pinyin_filter": {
        "type": "pinyin",
        "keep_first_letter": true,
        "keep_separate_first_letter": false,
        "keep_full_pinyin": true,
        "keep_joined_full_pinyin": true,
        "keep_original": true,
        "keep_none_chinese": true,
        "keep_none_chinese_together": true,
        "limit_first_letter_length": 16,
        "lowercase": true,
        "remove_duplicated_term": true
      },
      "edge_ngram_filter": {
        "type": "edge_ngram",
        "min_gram": 1,
        "max_gram": 20
      },
      "unique_filter": {
        "type": "unique",
        "only_on_same_position": false
      },
      "ngram_filter": {
        "type": "ngram",
        "min_gram": 2,
        "max_gram": 20
      }
    }
  }
}
